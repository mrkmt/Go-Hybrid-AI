# Example .env file for AI Testing Platform
# Copy to .env and update values before running

# Server
PORT=3000

# Optional API key (when set, required for POST /api/recordings, POST /api/triage/:id, POST /api/ai-logs)
# API_KEY=change-me

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Postgres
PG_USER=postgres
PG_PASSWORD=your_db_password
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ai_testing_platform
PG_MAX_CLIENTS=20
PG_IDLE_TIMEOUT=30000
PG_CONN_TIMEOUT=2000

# Ollama / Local LLM endpoints
OLLAMA_GENERATE_URL=http://localhost:11434/api/generate
OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings
DEFAULT_AI_MODEL=qwen2.5:latest
EMBED_MODEL=mxbai-embed-large:latest
AI_TIMEOUT_MS=15000

# Optional fallback model name (if Ollama has it)
# FALLBACK_AI_MODEL=llama3:latest

# Local knowledge paths (make these portable or override per-host)
GEMINI_PATH=C:\\Users\\<your_user>\\.gemini
QWEN_PATH=C:\\Users\\<your_user>\\.qwen
CODEX_PATH=C:\\Users\\<your_user>\\.codex
ANYTHINGLLM_PATH=C:\\Users\\<your_user>\\AppData\\Roaming\\anythingllm-desktop\\storage

# Extra knowledge roots to scan (comma or semicolon separated)
# KNOWLEDGE_PATHS=C:\\mydocs;D:\\kb

# Additional AI knowledge path (centralized)
EXTRA_KNOWLEDGE_PATH=D:\\KMT\\My class\\AI
