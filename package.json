{
  "name": "go-hybrid-ai",
  "version": "2.0.0",
  "description": "AI-assisted web-automation testing platform for Angular + Kendo",
  "main": "index.js",
  "scripts": {
    "test": "jest backend/validator/LeavePolicyValidator.test.ts",
    "test:all": "jest --testPathPattern=backend",
    "test:coverage": "jest --coverage --testPathPattern=backend",
    "start-api": "ts-node backend/api/server.ts",
    "start-kb": "cd frontend/kb-ui && npm run dev",
    "replay": "npx playwright test testing/replayer/replayer.spec.ts",
    "lint": "eslint backend/**/*.ts --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "ts-node backend/api/migrate.ts"
  },
  "dependencies": {
    "@types/node-fetch": "^2.6.13",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "playwright": "^1.40.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "backend/**/*.ts",
      "!backend/**/node_modules/**"
    ]
  }
}
