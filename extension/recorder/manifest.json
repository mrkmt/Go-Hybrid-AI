{
    "manifest_version": 3,
    "name": "Go-Hybrid AI Recorder",
    "version": "1.0",
    "description": "Captures user actions and network requests for automated testing.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "webRequest"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}